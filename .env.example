# Get free Gemini key at: https://aistudio.google.com
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Get Claude key at: https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Get OpenAI key at: https://platform.openai.com
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Get DeepSeek key at: https://platform.deepseek.com
VITE_DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Default provider: gemini | anthropic | openai | deepseek
VITE_DEFAULT_PROVIDER=gemini
